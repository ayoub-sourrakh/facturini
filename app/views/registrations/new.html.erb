<div class="text-center mb-8">
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight">Facturini</h1>
  <p class="mt-2 text-sm text-gray-500">Créez votre compte</p>
</div>

<div class="bg-white shadow-sm rounded-xl border border-gray-200 p-8">
  <% if @organization.errors.any? || @user.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg text-sm mb-6">
      <h2 class="font-medium">Erreurs :</h2>
      <ul class="list-disc ml-5 mt-1">
        <% (@organization.errors.full_messages + @user.errors.full_messages).each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <%= form_with url: registration_path, method: :post, class: "space-y-6", html: { autocomplete: "off" } do |f| %>

    <fieldset class="space-y-4">
      <legend class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Entreprise</legend>

      <div>
        <%= f.label "organization[name]", "Raison sociale", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field "organization[name]", required: true, value: @organization.name, placeholder: "Ma Société SAS",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
      </div>

      <div>
        <%= f.label "organization[email]", "Email de l'entreprise", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field "organization[email]", required: true, value: @organization.email, placeholder: "contact@masociete.fr",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
      </div>

      <div>
        <%= f.label "organization[invoice_prefix]", "Préfixe de facturation", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field "organization[invoice_prefix]", required: true, value: (@organization.invoice_prefix || "FAC"),
            placeholder: "FAC", maxlength: 3,
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary uppercase" %>
        <p class="text-xs text-gray-400 mt-1">3 lettres majuscules — ex: FAC, INV, BLT</p>
      </div>
    </fieldset>

    <hr class="border-gray-200">

    <fieldset class="space-y-4">
      <legend class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Votre compte</legend>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label "user[first_name]", "Prénom", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field "user[first_name]", required: true, value: @user.first_name,
              class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>
        <div>
          <%= f.label "user[last_name]", "Nom", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field "user[last_name]", required: true, value: @user.last_name,
              class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>
      </div>

      <div>
        <%= f.label "user[email]", "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field "user[email]", required: true, value: @user.email, placeholder: "vous@email.com",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
      </div>

      <div>
        <%= f.label "user[password]", "Mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field "user[password]", required: true, placeholder: "••••••••",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
      </div>

      <div>
        <%= f.label "user[password_confirmation]", "Confirmer le mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field "user[password_confirmation]", required: true, placeholder: "••••••••",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
      </div>
    </fieldset>

    <%= f.submit "Créer mon compte",
        class: "w-full py-2.5 px-4 bg-primary hover:bg-primary-dark text-white text-sm font-medium rounded-lg shadow-sm transition duration-150 cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
  <% end %>
</div>

<p class="mt-6 text-center text-sm text-gray-500">
  Déjà un compte ?
  <%= link_to "Se connecter", new_session_path, class: "font-medium text-primary hover:text-primary-dark" %>
</p>