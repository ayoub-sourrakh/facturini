<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Facturini" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="<%= asset_path 'facturini_logo_no_text.svg' %>" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <main class="w-full">
      <%= yield %>
    </main>
  </body>
</html>
