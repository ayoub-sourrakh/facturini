<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Facturini" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 min-h-screen flex flex-col justify-between">
      <div>
        <!-- Logo -->
        <div class="px-6 py-5 border-b border-gray-200">
          <%= link_to dashboard_path, class: "text-xl font-bold text-gray-900 tracking-tight" do %>
            Facturini
          <% end %>
        </div>

        <!-- Navigation -->
        <nav class="px-4 py-4 space-y-1">
          <%= link_to dashboard_path,
              class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg #{current_page?(dashboard_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <%= icon("chart-bar", css_class: "size-5 shrink-0") %> <span class="ml-3">Tableau de bord</span>
          <% end %>

          <%= link_to invoices_path,
              class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg #{request.path.start_with?('/invoices') ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <%= icon("document-text", css_class: "size-5 shrink-0") %> <span class="ml-3">Factures</span>
          <% end %>

          <%= link_to clients_path,
              class: "flex items-center px-3 py-2 text-sm font-medium rounded-lg #{request.path.start_with?('/clients') ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <%= icon("users", css_class: "size-5 shrink-0") %> <span class="ml-3">Clients</span>
          <% end %>
        </nav>
      </div>

      <!-- User section -->
      <div class="px-4 py-4 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <div class="text-sm">
            <p class="font-medium text-gray-900"><%= current_user.first_name %> <%= current_user.last_name %></p>
            <p class="text-gray-500 text-xs"><%= current_user.organization.name %></p>
          </div>
          <%= button_to destroy_session_path, method: :delete, class: "text-gray-400 hover:text-red-600 text-sm" do %>
            <%= icon("arrow-right-on-rectangle", css_class: "size-5") %>
          <% end %>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <div class="max-w-7xl mx-auto px-6 py-8">
        <% if flash[:alert] %>
          <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
            <%= flash[:alert] %>
          </div>
        <% end %>
        <% if flash[:notice] %>
          <div class="mb-6 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm">
            <%= flash[:notice] %>
          </div>
        <% end %>
        <%= yield %>
      </div>
    </main>

  </body>
</html>