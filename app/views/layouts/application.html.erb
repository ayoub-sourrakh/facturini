<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Facturini" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="<%= asset_path 'facturini_logo_no_text.svg' %>" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col md:flex-row">
    <!-- Header Mobile -->
    <header class="md:hidden bg-white border-b border-gray-200 px-4 py-3 flex items-center justify-between">
      <%= link_to dashboard_path, class: "text-xl font-bold text-gray-900 tracking-tight" do %>
        <%= image_tag "facturini_logo_text_only.svg", class: "h-7 sm:h-9 w-auto", alt: "Facturini" %>
      <% end %>
      <button id="mobile-menu-btn" class="p-2 text-gray-600 hover:text-gray-900 focus:outline-none">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </header>

    <!-- Sidebar -->
    <aside id="sidebar" class="hidden md:flex w-64 bg-white border-r border-gray-200 flex-col justify-between fixed inset-y-0 left-0 z-50 md:sticky md:top-0 md:h-screen">
      <div>
        <!-- Logo -->
        <div class="px-6 py-5 border-b border-gray-200 flex items-center justify-between">
          <%= link_to dashboard_path, class: "text-xl font-bold text-gray-900 tracking-tight" do %>
            <%= image_tag "facturini_logo_text_only.svg", class: "h-7 sm:h-9 w-auto", alt: "Facturini" %>
          <% end %>
          <button id="mobile-menu-close" class="md:hidden p-2 text-gray-600 hover:text-gray-900">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Navigation -->
        <nav class="px-3 py-4 space-y-2">
          <%= link_to dashboard_path,
              class: "flex items-center px-4 py-3 text-base font-medium rounded-lg #{current_page?(dashboard_path) ? 'bg-primary/10 text-primary' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <%= icon("chart-bar", css_class: "size-6 shrink-0") %> <span class="ml-4">Tableau de bord</span>
          <% end %>

          <%= link_to invoices_path,
              class: "flex items-center px-4 py-3 text-base font-medium rounded-lg #{request.path.start_with?('/invoices') ? 'bg-primary/10 text-primary' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <%= icon("document-text", css_class: "size-6 shrink-0") %> <span class="ml-4">Factures</span>
          <% end %>

          <%= link_to clients_path,
              class: "flex items-center px-4 py-3 text-base font-medium rounded-lg #{request.path.start_with?('/clients') ? 'bg-primary/10 text-primary' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <%= icon("users", css_class: "size-6 shrink-0") %> <span class="ml-4">Clients</span>
          <% end %>

          <% if current_user&.owner? || current_user&.admin? %>
            <%= link_to users_path,
                class: "flex items-center px-4 py-3 text-base font-medium rounded-lg #{request.path.start_with?('/users') ? 'bg-primary/10 text-primary' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <%= icon("user-group", css_class: "size-6 shrink-0") %> <span class="ml-4">Utilisateurs</span>
            <% end %>
          <% end %>

          <% if current_user&.admin? %>
            <%= link_to organizations_path,
                class: "flex items-center px-4 py-3 text-base font-medium rounded-lg #{request.path.start_with?('/organizations') ? 'bg-primary/10 text-primary' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <%= icon("building-office", css_class: "size-6 shrink-0") %> <span class="ml-4">Organisations</span>
            <% end %>
          <% end %>
        </nav>
      </div>

      <!-- User section -->
      <% if signed_in? %>
        <div class="px-4 py-4 border-t border-gray-200">
          <div class="flex items-center justify-between">
            <div class="text-base min-w-0 flex-1">
              <%= link_to profile_path, class: "block hover:opacity-75 transition" do %>
                <p class="font-medium text-gray-900 truncate"><%= current_user.first_name %> <%= current_user.last_name %></p>
                <p class="text-gray-500 text-sm truncate"><%= current_user.organization&.name || current_user.email %></p>
              <% end %>
            </div>
            <%= button_to destroy_session_path, method: :delete, class: "text-gray-400 hover:text-red-600 ml-2 shrink-0" do %>
              <%= icon("arrow-right-on-rectangle", css_class: "size-6") %>
            <% end %>
          </div>
        </div>
      <% end %>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto w-full">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
        <script>
          document.getElementById('mobile-menu-btn')?.addEventListener('click', function() {
            document.getElementById('sidebar').classList.remove('hidden');
          });
          document.getElementById('mobile-menu-close')?.addEventListener('click', function() {
            document.getElementById('sidebar').classList.add('hidden');
          });
        </script>
        <% if flash[:alert] %>
          <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
            <%= flash[:alert] %>
          </div>
        <% end %>
        <% if flash[:notice] %>
          <div class="mb-6 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm">
            <%= flash[:notice] %>
          </div>
        <% end %>
        <%= yield %>
      </div>
    </main>

  </body>
</html>