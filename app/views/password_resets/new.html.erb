<% content_for :title, "Mot de passe oublié - Facturini" %>

<div class="text-center mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Facturini</h1>
  <p class="mt-2 text-gray-600">Mot de passe oublié</p>
</div>

<div class="bg-white shadow-sm rounded-xl border border-gray-200 p-8">
  <%= form_with url: password_resets_path, class: "space-y-5" do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, required: true, placeholder: "vous@exemple.com", autocomplete: "off",
          class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <%= f.submit "Envoyer les instructions",
        class: "w-full py-2.5 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg shadow-sm transition duration-150 cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
  <% end %>
</div>

<p class="mt-6 text-center text-sm text-gray-500">
  <%= link_to "Retour à la connexion", new_session_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
</p>