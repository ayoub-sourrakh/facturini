<!DOCTYPE html>
<html>
<head>
  <title>Mot de passe oublié - Facturini</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Facturini</h1>
      <p class="mt-2 text-gray-600">Mot de passe oublié</p>
    </div>

    <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-8">
      <%= form_with url: password_resets_path, class: "space-y-5" do |f| %>
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, required: true, placeholder: "vous@exemple.com", autocomplete: "off",
              class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <%= f.submit "Envoyer les instructions",
            class: "w-full py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 cursor-pointer" %>
      <% end %>
    </div>

    <p class="mt-6 text-center text-sm">
      <%= link_to "Retour à la connexion", new_session_path, class: "text-indigo-600 hover:text-indigo-500" %>
    </p>
  </div>
</body>
</html>