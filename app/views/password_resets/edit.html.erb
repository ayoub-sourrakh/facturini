<% content_for :title, "Nouveau mot de passe - Facturini" %>

<div class="text-center mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Facturini</h1>
  <p class="mt-2 text-gray-600">Nouveau mot de passe</p>
</div>

<div class="bg-white shadow-sm rounded-xl border border-gray-200 p-8">
  <%= form_with model: @user, url: password_reset_path(params[:id]), class: "space-y-5" do |f| %>
    <div>
      <%= f.label :password, "Nouveau mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, required: true, placeholder: "••••••••", autocomplete: "new-password",
          class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirmation", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, required: true, placeholder: "••••••••", autocomplete: "new-password",
          class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <%= f.submit "Réinitialiser",
        class: "w-full py-2.5 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg shadow-sm transition duration-150 cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
  <% end %>
</div>