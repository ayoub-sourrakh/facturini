<% if organization.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg text-sm mb-6">
    <h2 class="font-medium"><%= pluralize(organization.errors.count, "erreur") %> :</h2>
    <ul class="list-disc ml-5 mt-1">
      <% organization.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: organization, class: "space-y-5", html: { autocomplete: "off" } do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= f.label :name, "Nom de l'organisation", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, required: true, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :phone, "Téléphone", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.telephone_field :phone, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :invoice_prefix, "Préfixe factures (3 lettres majuscules)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :invoice_prefix, required: true, maxlength: 3, placeholder: "FAC", class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary uppercase" %>
    </div>

    <div>
      <%= f.label :siret, "SIRET", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :siret, maxlength: 14, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :siren, "SIREN", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :siren, maxlength: 9, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :vat_number, "Numéro TVA", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :vat_number, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :legal_form, "Forme juridique", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :legal_form, placeholder: "SARL, SAS, EI...", class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :capital, "Capital social (€)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :capital, min: 0, step: 0.01, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :country, "Pays", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :country, value: organization.country.presence || "FR", class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
  </div>

  <div>
    <%= f.label :address, "Adresse", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :address, rows: 2, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :city, "Ville", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :city, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
    <div>
      <%= f.label :zip_code, "Code postal", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :zip_code, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
  </div>

  <div>
    <%= label_tag :owner_id, "Propriétaire (owner)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% current_owner = organization.users.find_by(role: :owner) %>
    <% available_users = User.where(organization_id: nil).order(:last_name) %>
    <% available_users = (available_users + [ current_owner ]).compact.uniq if current_owner %>
    <%= select_tag :owner_id,
        options_from_collection_for_select(available_users, :id, ->(u) { "#{u.first_name} #{u.last_name} (#{u.email})" }, current_owner&.id),
        include_blank: organization.new_record? ? "Sélectionner un utilisateur..." : nil,
        required: organization.new_record?,
        class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>

  <div class="flex items-center space-x-4 pt-2">
    <%= f.submit organization.new_record? ? "Créer l'organisation" : "Enregistrer",
        class: "bg-primary text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-primary-dark transition cursor-pointer" %>
    <%= link_to "Annuler", organizations_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
