<% is_new = user.new_record? %>

<% if user.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg text-sm mb-6">
    <h2 class="font-medium"><%= pluralize(user.errors.count, "erreur") %> :</h2>
    <ul class="list-disc ml-5 mt-1">
      <% user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: user, class: "space-y-5", html: { autocomplete: "off" } do |f| %>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, "Prénom", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :first_name, required: true, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
    <div>
      <%= f.label :last_name, "Nom", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :last_name, required: true, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
  </div>

  <div>
    <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.email_field :email, required: true, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>

  <div>
    <%= f.label :role, "Rôle", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :role, [["Membre", "member"], ["Admin", "admin"], ["Propriétaire", "owner"]],
        {},
        { class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary",
          disabled: !is_new && user == current_user } %>
    <% if !is_new && user == current_user %>
      <p class="text-xs text-gray-400 mt-1">Vous ne pouvez pas modifier votre propre rôle.</p>
    <% end %>
  </div>

  <div>
    <%= f.label :password, is_new ? "Mot de passe" : "Nouveau mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.password_field :password, required: is_new, placeholder: is_new ? "" : "Laisser vide pour ne pas changer",
        class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.password_field :password_confirmation, required: is_new,
        class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>

  <div class="flex items-center space-x-4 pt-2">
    <%= f.submit is_new ? "Créer l'utilisateur" : "Enregistrer",
        class: "bg-primary text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-primary-dark transition cursor-pointer" %>
    <%= link_to "Annuler", users_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
