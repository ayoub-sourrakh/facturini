<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @client.name %></h1>
      <p class="text-gray-600"><%= @client.client_type == "professional" ? "Professionnel" : "Particulier" %></p>
    </div>
    <div class="space-x-2">
      <%= link_to "Modifier", edit_client_path(@client), class: "text-indigo-600 hover:text-indigo-900" %>
      <%= link_to "Retour", clients_path, class: "text-gray-600 hover:text-gray-900" %>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-6 space-y-4">
    <% if @client.email.present? %>
      <div>
        <p class="text-sm text-gray-500">Email</p>
        <p><%= @client.email %></p>
      </div>
    <% end %>

    <% if @client.phone.present? %>
      <div>
        <p class="text-sm text-gray-500">Téléphone</p>
        <p><%= @client.phone %></p>
      </div>
    <% end %>

    <% if @client.address.present? %>
      <div>
        <p class="text-sm text-gray-500">Adresse</p>
        <p><%= @client.address %></p>
        <p><%= @client.zip_code %> <%= @client.city %></p>
        <p><%= @client.country %></p>
      </div>
    <% end %>

    <% if @client.siret.present? %>
      <div>
        <p class="text-sm text-gray-500">SIRET</p>
        <p><%= @client.siret %></p>
      </div>
    <% end %>
  </div>
</div>