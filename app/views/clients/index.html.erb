<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Mes clients</h1>
    <%= link_to "Nouveau client", new_client_path, class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
  </div>

  <% if @clients.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nom</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Téléphone</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @clients.each do |client| %>
          <tr>
            <td class="px-6 py-4"><%= link_to client.name, client_path(client), class: "text-indigo-600 hover:text-indigo-900" %></td>
            <td class="px-6 py-4"><%= client.email %></td>
            <td class="px-6 py-4"><%= client.phone %></td>
            <td class="px-6 py-4"><%= client.client_type %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-500">Aucun client. <%= link_to "Créer votre premier client", new_client_path, class: "text-indigo-600" %>.</p>
  <% end %>
</div>