<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Nouveau client</h1>

  <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-8">
    <%= form_with model: @client, class: "space-y-5" do |f| %>
      <% if @client.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg text-sm">
          <h2 class="font-medium"><%= pluralize(@client.errors.count, "erreur") %> :</h2>
          <ul class="list-disc ml-5 mt-1">
            <% @client.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Nom / Raison sociale", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, required: true, placeholder: "Nom du client",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= f.label :client_type, "Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :client_type, [["Particulier", "individual"], ["Professionnel", "professional"]], {},
            { class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" } %>
      </div>

      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, placeholder: "client@exemple.com",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= f.label :phone, "Téléphone", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.telephone_field :phone, placeholder: "01 23 45 67 89",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= f.label :address, "Adresse", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :address, rows: 3,
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :city, "Ville", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :city,
              class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
        <div>
          <%= f.label :zip_code, "Code postal", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :zip_code,
              class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>

      <div>
        <%= f.label :country, "Pays", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :country, value: "FR",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div class="flex items-center space-x-4 pt-2">
        <%= f.submit "Créer le client",
            class: "bg-indigo-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        <%= link_to "Annuler", clients_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
      </div>
    <% end %>
  </div>
</div>