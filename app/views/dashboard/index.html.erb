<div class="min-h-screen bg-gray-100">
    <% if flash[:alert] %>
  <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
    <%= flash[:alert] %>
  </div>
<% end %>

<% if flash[:notice] %>
  <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded">
    <%= flash[:notice] %>
  </div>
<% end %>
  <!-- Header -->
  <nav class="bg-white shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center">
          <h1 class="text-xl font-bold text-gray-900">Facturini</h1>
        </div>
        <div class="flex items-center space-x-4">
          <span class="text-gray-700"><%= current_user.first_name %> <%= current_user.last_name %></span>
          <%= button_to "Déconnexion", destroy_session_path, method: :delete,
              class: "text-sm text-red-600 hover:text-red-500" %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main content -->
  <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <div class="px-4 py-6 sm:px-0">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Tableau de bord - <%= @organization.name %></h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Stats cards -->
        <div class="bg-white overflow-hidden shadow rounded-lg">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-gray-500 truncate">Factures</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= @invoices_count %></dd>
          </div>
          <div class="mt-8">
            <%= link_to "Voir mes factures", invoices_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200" %>
          </div>
        </div>

        <div class="bg-white overflow-hidden shadow rounded-lg">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-gray-500 truncate">Clients</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900"><%= @clients_count %></dd>
          </div>
          <div class="mt-8">
            <%= link_to "Voir mes clients", clients_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200" %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>