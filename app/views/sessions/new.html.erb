<div class="text-center mb-8">
  <%= link_to root_path do %>
    <%= image_tag "facturini_logo_text_only.svg", class: "h-8 sm:h-10 w-auto mx-auto mb-3", alt: "Facturini" %>
  <% end %>
  <p class="mt-2 text-sm text-gray-500">Connectez-vous à votre compte</p>
</div>

<div class="bg-white shadow-sm rounded-xl border border-gray-200 p-8">
  <%= form_with url: session_path, method: :post, class: "space-y-5", html: { autocomplete: "off" } do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, required: true, autofocus: true, placeholder: "vous@entreprise.com",
          class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, required: true, placeholder: "••••••••",
          class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>

    <%= f.submit "Se connecter",
        class: "w-full py-2.5 px-4 bg-primary hover:bg-primary-dark text-white text-sm font-medium rounded-lg shadow-sm transition duration-150 cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
  <% end %>
</div>

<p class="mt-6 text-center text-sm text-gray-500">
  <%= link_to "Mot de passe oublié ?", new_password_reset_path, class: "font-medium text-primary hover:text-primary-dark" %>
</p>