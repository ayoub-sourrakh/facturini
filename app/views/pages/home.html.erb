<% content_for :title, "Facturini - Gérez vos factures simplement" %>

<!-- Hero + Features Section -->
<section class="bg-gradient-to-b from-primary/5 to-gray-50 py-8 sm:py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto text-center">
    <h1 class="flex justify-center mb-4">
      <%= image_tag "facturini_logo.svg", class: "h-32 sm:h-48 w-auto", alt: "Facturini" %>
    </h1>
    <p class="text-lg sm:text-xl text-primary/80 mb-6 max-w-3xl mx-auto">
      La facturation simple et rapide pour les indépendants et PME
    </p>
    <%= link_to "Se connecter", new_session_path,
        class: "inline-block px-6 py-3 bg-primary text-white text-base font-medium rounded-xl hover:bg-primary-dark transition shadow-lg mb-10" %>
  </div>

  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-8 bg-white rounded-2xl border border-gray-200 shadow-sm">
        <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3">Factures illimitées</h3>
        <p class="text-gray-600 leading-relaxed">Créez et gérez vos factures professionnelles en quelques clics. Export PDF automatique.</p>
      </div>

      <div class="p-8 bg-white rounded-2xl border border-gray-200 shadow-sm">
        <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3">Gestion clients</h3>
        <p class="text-gray-600 leading-relaxed">Organisez votre base clients avec toutes les informations importantes en un seul endroit.</p>
      </div>

      <div class="p-8 bg-white rounded-2xl border border-gray-200 shadow-sm">
        <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3">Sécurisé</h3>
        <p class="text-gray-600 leading-relaxed">Vos données sont chiffrées et protégées. Accès sécurisé par mot de passe.</p>
      </div>
    </div>
  </div>
</section>

<%= render "layouts/footer" %>
