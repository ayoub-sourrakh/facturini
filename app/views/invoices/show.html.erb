<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Facture <%= @invoice.number %></h1>
      <p class="text-sm text-gray-500 mt-1"><%= @invoice.client.name %></p>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium mt-2 <%= invoice_status_badge_class(@invoice) %>">
        <%= invoice_status_label(@invoice) %>
        <% if @invoice.sent_at %>
          — <%= l @invoice.sent_at, format: :short %>
        <% end %>
      </span>
    </div>
    <div class="flex items-center space-x-2">
      <%# PDF : finalized, sent, paid %>
      <% if @invoice.downloadable? %>
        <%= link_to download_pdf_invoice_path(@invoice),
            class: "inline-flex items-center space-x-1.5 bg-gray-100 text-gray-700 px-5 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition" do %>
          <%= icon("arrow-down-tray", css_class: "size-4") %>
          <span>PDF</span>
        <% end %>
      <% end %>

      <%# Finaliser : draft avec items et due_date %>
      <% if @invoice.finalizable? %>
        <%= button_to finalize_invoice_invoice_path(@invoice), method: :patch,
            class: "inline-flex items-center space-x-1.5 bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition" do %>
          <%= icon("check-circle", css_class: "size-4") %>
          <span>Finaliser</span>
        <% end %>
      <% elsif @invoice.draft? && @invoice.invoice_items.any? && @invoice.due_date.blank? %>
        <span class="inline-flex items-center space-x-1.5 text-xs text-amber-600">
          <%= icon("exclamation-triangle", css_class: "size-4") %>
          <span>Date d'échéance requise pour finaliser</span>
        </span>
      <% end %>

      <%# Modifier : draft %>
      <% if @invoice.editable? %>
        <%= link_to edit_invoice_path(@invoice),
            class: "inline-flex items-center space-x-1.5 bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary-dark transition" do %>
          <%= icon("pencil-square", css_class: "size-4") %>
          <span>Modifier</span>
        <% end %>
      <% end %>

      <%# Envoyer : finalized %>
      <% if @invoice.sendable? %>
        <%= button_to send_invoice_invoice_path(@invoice), method: :patch,
            class: "inline-flex items-center space-x-1.5 bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition",
            data: { turbo_confirm: "Confirmer l'envoi ?" } do %>
          <%= icon("paper-airplane", css_class: "size-4") %>
          <span>Envoyer</span>
        <% end %>
      <% end %>

      <%# Marquer payée : sent %>
      <% if @invoice.payable? %>
        <%= button_to mark_as_paid_invoice_path(@invoice), method: :patch,
            class: "inline-flex items-center space-x-1.5 bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary-dark transition" do %>
          <%= icon("banknotes", css_class: "size-4") %>
          <span>Marquer payée</span>
        <% end %>
      <% end %>

      <%# Annuler : finalized %>
      <% if @invoice.cancellable? %>
        <%= button_to cancel_invoice_invoice_path(@invoice), method: :patch,
            class: "inline-flex items-center space-x-1.5 bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-red-100 transition",
            form: { data: { turbo_confirm: "Annuler cette facture ?" } } do %>
          <%= icon("x-mark", css_class: "size-4") %>
          <span>Annuler</span>
        <% end %>
      <% end %>

      <%# Supprimer : draft %>
      <% if @invoice.editable? %>
        <%= button_to invoice_path(@invoice), method: :delete,
            class: "inline-flex items-center space-x-1.5 bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-red-100 transition",
            form: { data: { turbo_confirm: "Supprimer cette facture ?" } } do %>
          <%= icon("trash", css_class: "size-4") %>
          <span>Supprimer</span>
        <% end %>
      <% end %>

      <%= link_to invoices_path, class: "inline-flex items-center space-x-1.5 text-sm text-gray-500 hover:text-gray-700 transition" do %>
        <%= icon("arrow-left", css_class: "size-4") %>
        <span>Retour</span>
      <% end %>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-6 mb-6">
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Date d'émission</p>
        <p class="mt-1 text-sm text-gray-900"><%= l @invoice.issue_date %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Date d'échéance</p>
        <p class="mt-1 text-sm text-gray-900"><%= l @invoice.due_date if @invoice.due_date %></p>
      </div>
    </div>

    <% if @invoice.subject.present? %>
      <div class="mb-6">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Objet</p>
        <p class="mt-1 text-sm text-gray-900"><%= @invoice.subject %></p>
      </div>
    <% end %>

    <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Lignes de facture</h2>

    <% if @invoice.invoice_items.any? %>
      <div class="border border-gray-200 rounded-lg overflow-hidden mb-4">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Qté</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Prix unit.</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">TVA %</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @invoice.invoice_items.each do |item| %>
              <tr class="hover:bg-gray-50 transition">
                <td class="px-4 py-3 text-sm text-gray-900"><%= item.description %></td>
                <td class="px-4 py-3 text-sm text-gray-700 text-right"><%= item.quantity %></td>
                <td class="px-4 py-3 text-sm text-gray-700 text-right"><%= number_to_currency(item.unit_price_cents / 100.0, unit: "€") %></td>
                <td class="px-4 py-3 text-sm text-gray-700 text-right"><%= item.vat_rate %>%</td>
                <td class="px-4 py-3 text-right">
                  <% if @invoice.editable? %>
                    <%= button_to invoice_invoice_item_path(@invoice, item), method: :delete,
                        class: "text-gray-400 hover:text-red-600 transition", form: { data: { turbo_confirm: "Supprimer cette ligne ?" } } do %>
                      <%= icon("x-mark", css_class: "size-4") %>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="text-right space-y-1 pt-2">
        <p class="text-sm text-gray-500">Total HT : <%= number_to_currency(@invoice.subtotal_cents / 100.0, unit: "€") %></p>
        <p class="text-sm text-gray-500">TVA : <%= number_to_currency(@invoice.vat_amount_cents / 100.0, unit: "€") %></p>
        <p class="text-lg font-bold text-gray-900">Total TTC : <%= number_to_currency(@invoice.total_cents / 100.0, unit: "€") %></p>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm mb-4">Aucune ligne. Ajoutez votre première ligne ci-dessous.</p>
    <% end %>

    <% if @invoice.editable? %>
      <div class="mt-6 pt-6 border-t border-gray-200">
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">Ajouter une ligne</h3>
        <%= form_with model: [@invoice, InvoiceItem.new], class: "grid grid-cols-12 gap-3 items-end", html: { autocomplete: "off" } do |f| %>
          <div class="col-span-4">
            <%= f.label :description, "Description", class: "block text-xs font-medium text-gray-700 mb-1" %>
            <%= f.text_field :description, required: true, placeholder: "Prestation...",
                class: "block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
          </div>
          <div class="col-span-2">
            <%= f.label :quantity, "Qté", class: "block text-xs font-medium text-gray-700 mb-1" %>
            <%= f.number_field :quantity, step: 0.01, value: 1, required: true,
                class: "block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
          </div>
          <div class="col-span-3">
            <%= f.label :unit_price_cents, "Prix unit. (centimes)", class: "block text-xs font-medium text-gray-700 mb-1" %>
            <%= f.number_field :unit_price_cents, value: 10000, required: true,
                class: "block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
          </div>
          <div class="col-span-2">
            <%= f.label :vat_rate, "TVA %", class: "block text-xs font-medium text-gray-700 mb-1" %>
            <%= f.number_field :vat_rate, step: 0.01, value: 20, required: true,
                class: "block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
          </div>
          <div class="col-span-1">
            <%= f.submit "+",
                class: "w-full bg-primary text-white px-3 py-2 rounded-lg hover:bg-primary-dark font-bold text-sm transition cursor-pointer" %>
          </div>
        <% end %>
        <p class="text-xs text-gray-400 mt-2">Prix en centimes : 10000 = 100€, 5000 = 50€, etc.</p>
      </div>
    <% end %>
  </div>
</div>