<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Mes factures</h1>
    <%= link_to "Nouvelle facture", new_invoice_path, class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
  </div>

  <% if @invoices.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">N°</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Client</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Total</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @invoices.each do |invoice| %>
          <tr>
            <td class="px-6 py-4"><%= link_to invoice.number, invoice_path(invoice), class: "text-indigo-600 hover:text-indigo-900" %></td>
            <td class="px-6 py-4"><%= invoice.client.name %></td>
            <td class="px-6 py-4"><%= l invoice.issue_date %></td>
            <td class="px-6 py-4"><%= number_to_currency(invoice.total_cents / 100.0, unit: "€") %></td>
            <td class="px-6 py-4"><%= invoice.status %></td>
            <td class="px-6 py-4">
              <%= link_to "Voir", invoice_path(invoice), class: "text-indigo-600 hover:text-indigo-900" %>
              <% if invoice.draft? %>
                <%= link_to "Modifier", edit_invoice_path(invoice), class: "text-indigo-600 hover:text-indigo-900 ml-2" %>
                <%= button_to "Supprimer", invoice_path(invoice), method: :delete,
                    class: "text-red-600 hover:text-red-800 ml-2 inline", form: { data: { turbo_confirm: "Supprimer cette facture ?" } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-500">Aucune facture. <%= link_to "Créer votre première facture", new_invoice_path, class: "text-indigo-600" %>.</p>
  <% end %>
</div>