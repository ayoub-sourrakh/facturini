<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Mes factures</h1>
  <%= link_to "Nouvelle facture", new_invoice_path, class: "bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition" %>
</div>

<% if @invoices.any? %>
  <div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">N°</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Client</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Total</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @invoices.each do |invoice| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-6 py-4 text-sm"><%= link_to invoice.number, invoice_path(invoice), class: "font-medium text-indigo-600 hover:text-indigo-500" %></td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= invoice.client.name %></td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= l invoice.issue_date %></td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= number_to_currency(invoice.total_cents / 100.0, unit: "€") %></td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= invoice.draft? ? 'bg-gray-100 text-gray-700' : 'bg-green-100 text-green-700' %>">
                <%= invoice.status == "draft" ? "Brouillon" : "Envoyée" %>
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center space-x-2">
                <%= link_to invoice_path(invoice), title: "Voir", class: "text-gray-400 hover:text-indigo-600 transition" do %>
                  <%= icon("eye", css_class: "size-4") %>
                <% end %>
                <% if invoice.draft? %>
                  <%= link_to edit_invoice_path(invoice), title: "Modifier", class: "text-gray-400 hover:text-indigo-600 transition" do %>
                    <%= icon("pencil-square", css_class: "size-4") %>
                  <% end %>
                  <%= button_to invoice_path(invoice), method: :delete, title: "Supprimer",
                      class: "text-gray-400 hover:text-red-600 transition", form: { data: { turbo_confirm: "Supprimer cette facture ?" } } do %>
                    <%= icon("trash", css_class: "size-4") %>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-gray-500 text-sm">Aucune facture. <%= link_to "Créer votre première facture", new_invoice_path, class: "text-indigo-600 hover:text-indigo-500" %>.</p>
<% end %>