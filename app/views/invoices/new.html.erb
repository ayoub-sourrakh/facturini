<div class="max-w-2xl mx-auto">
  <h1 class="text-xl sm:text-2xl font-bold text-gray-900 mb-6">Nouvelle facture</h1>

  <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-8">
    <%= form_with model: @invoice, class: "space-y-5", html: { autocomplete: "off" } do |f| %>
      <% if @invoice.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg text-sm">
          <h2 class="font-medium"><%= pluralize(@invoice.errors.count, "erreur") %> :</h2>
          <ul class="list-disc ml-5 mt-1">
            <% @invoice.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :client_id, "Client", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.collection_select :client_id, @clients, :id, :name, { include_blank: "Sélectionner..." },
            { required: true, class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" } %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :issue_date, "Date d'émission", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :issue_date, value: Date.today, required: true,
              class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>
        <div>
          <%= f.label :due_date, "Date d'échéance", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :due_date, value: 30.days.from_now.to_date,
              class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
        </div>
      </div>

      <div>
        <%= f.label :subject, "Objet", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :subject, placeholder: "Prestation de conseil — Juin 2025",
            class: "block w-full px-3 py-2.5 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
      </div>

      <div class="flex items-center space-x-4 pt-2">
        <%= f.submit "Créer la facture",
            class: "bg-primary text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-primary-dark transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
        <%= link_to "Annuler", invoices_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
      </div>
    <% end %>
  </div>
</div>